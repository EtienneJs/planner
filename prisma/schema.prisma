// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"                                      
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String   @id @default(cuid())
  email    String   @unique
  password String
  events   Event[]
  purchases Purchase[]
}

model Event {
  id        String   @id @default(cuid())
  title     String
  startTime DateTime
  endTime   DateTime
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}

model Purchase {
  id     String   @id @default(cuid())
  description   String
  price  Int
  date   DateTime @default(now())
  userId String
  user   User     @relation(fields: [userId], references: [id])
  detailProducts PurchaseDetailProduct[]
}

model PurchaseDetailProduct {
  id         String   @id @default(cuid())
  purchaseId String
  productId  String
  cantidad   Int
  total      Int    // o Int si prefieres enteros

  purchase Purchase @relation(fields: [purchaseId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])

  @@unique([purchaseId, productId])
}


model Product {
  id     String   @id @default(cuid())
  name   String 
  price  Int
  purchaseDetails PurchaseDetailProduct[]
}

